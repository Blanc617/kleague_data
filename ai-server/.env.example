# 네이버 검색 API (https://developers.naver.com 에서 발급)
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# OpenAI (임베딩 text-embedding-3-small + LLM gpt-4o-mini)
OPENAI_API_KEY=your_openai_api_key

# Supabase pgvector
# SUPABASE_URL: Dashboard > Settings > API > Project URL
# SUPABASE_SERVICE_KEY: Dashboard > Settings > API > service_role (secret) — anon 키 사용 불가
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Redis 캐시
# 로컬: redis://localhost:6379/0
# Railway Redis: redis://default:password@host:port/0
REDIS_URL=redis://localhost:6379/0
